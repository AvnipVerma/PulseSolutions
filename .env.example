DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/DATABASE_NAME"
# Use accept_invalid_certs only for local development when your OS doesn't trust the DB provider CA.
DATABASE_SSL_ACCEPT="strict"
GEMINI_API_KEY="your_gemini_api_key"
QDRANT_URL="https://your-cluster-id.region.cloud.qdrant.io"
QDRANT_API_KEY="your_qdrant_database_api_key"
QDRANT_COLLECTION_NAME="documents"
