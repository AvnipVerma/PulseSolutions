generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Document {
  id        Int       @id @default(autoincrement())
  title     String    @db.VarChar(255)
  content   String    @db.Text
  url       String    @db.VarChar(255)
  createdAt DateTime? @default(now()) @db.Timestamp(0)

  @@index([createdAt])
  @@map("documents")
}
